# AI_PROVIDER_MODEL=llama3.2:3b

# Option B – OpenAI (paid)
# AI_PROVIDER_BASE_URL=https://api.openai.com/v1
# AI_PROVIDER_API_KEY=your_api_key
# AI_PROVIDER_MODEL=gpt-3.5-turbo

# Site
SITE_URL=http://localhost:3000